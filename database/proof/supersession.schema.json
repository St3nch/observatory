{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:observatory:db4:supersession:v1",
  "title": "DB-4 Result Supersession",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","supersession_id","prior_execution_id","replacement_execution_id","authority_reference","reason"],
  "properties": {
    "schema_version": {"const": "1"},
    "supersession_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{7,127}$"},
    "prior_execution_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{7,127}$"},
    "replacement_execution_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{7,127}$"},
    "authority_reference": {"type": "string", "pattern": "^decisions/.+\\.md$"},
    "reason": {"type": "string", "minLength": 1, "maxLength": 2000}
  }
}
