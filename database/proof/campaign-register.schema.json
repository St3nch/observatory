{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:observatory:db4:campaign-register:v1",
  "title": "DB-4 Campaign Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","campaign_id","authority_reference","database_class","profile_ids","execution_ids","started_at","finished_at","status","reviewer_state"],
  "properties": {
    "schema_version": {"const": "1"},
    "campaign_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{7,127}$"},
    "authority_reference": {"type": "string", "pattern": "^decisions/.+\\.md$"},
    "database_class": {"const": "disposable_postgres"},
    "profile_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "execution_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{7,127}$"}},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": ["string","null"], "format": "date-time"},
    "status": {"enum": ["planned","running","passed","failed","blocked","aborted"]},
    "reviewer_state": {"enum": ["unreviewed","accepted","rejected","superseded"]}
  }
}
